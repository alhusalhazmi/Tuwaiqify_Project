# Telegram Configuration
# Create a bot via @BotFather to get the token
TELEGRAM_BOT_TOKEN=
# Get your chat ID via @userinfobot
TELEGRAM_CHAT_ID=

# Google Sheets Configuration
# The ID of your Google Sheet (found in the URL)
GOOGLE_SHEET_ID=
# Service Account Email (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Service Account Private Key (from Google Cloud Console)
# Make sure to include the full key with \n for newlines
GOOGLE_PRIVATE_KEY=
